generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MULTI-TENANT
// ==========================================

model Tenant {
  id               String               @id @default(uuid())
  name             String // Nom de l'entreprise
  subdomain        String               @unique // Sous-domaine unique
  logo             String? // URL du logo
  address          String?
  phone            String?
  email            String?
  currency         Currency             @default(MRU) // Devise par défaut
  leaveCarryOver   LeaveCarryOverPolicy @default(CONFIGURABLE)
  maxCarryOverDays Int? // Plafond de report (si applicable)
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  users               User[]
  employees           Employee[]
  departments         Department[]
  grades              Grade[]
  advantages          Advantage[]
  leaveTypes          LeaveType[]
  payrolls            Payroll[]
  declarations        Declaration[]
  onboardingTemplates OnboardingTemplate[]
  settings            TenantSettings?
  auditLogs           AuditLog[]
  signatureRequests   SignatureRequest[]
  holidays            Holiday[]
  attendances         Attendance[]
  attendanceConfig    AttendanceConfig?
  overtimeConfig      OvertimeConfig?
  overtimes           Overtime[]
  salaryAdvances      SalaryAdvance[]
  taxConfig           TaxConfig?
  expenseReports      ExpenseReport[]
  evaluationCampaigns EvaluationCampaign[]
  evaluations         Evaluation[]
  sanctions           Sanction[]
  orgLevels           OrgLevel[]
}

model TenantSettings {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  fiscalYearStart Int      @default(1) // Mois de début de l'exercice fiscal (1 = janvier)
  workDaysPerWeek    Int      @default(5)
  weekStartDay       Int      @default(1) // 1 = Lundi, 7 = Dimanche
  defaultLeaveDays   Int      @default(24) // Nombre de jours de congé annuel par défaut
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPassword    String?
  smtpFromEmail   String?
  smtpFromName    String?
  contractTemplate String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// UTILISATEURS & AUTHENTIFICATION
// ==========================================

model User {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  email        String
  phone        String?
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  refreshToken String?
  permissions  Json?     // [{key: string, expiresAt: string}] — temporary permissions for HR
  employeeId   String?   @unique
  employee     Employee? @relation(fields: [employeeId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
}

// ==========================================
// EMPLOYÉS
// ==========================================

model Employee {
  id              String         @id @default(uuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  matricule       String // Matricule auto-généré
  firstName       String
  lastName        String
  cin             String? // CIN ou Passeport
  dateOfBirth     DateTime?
  gender          Gender?
  address         String?
  phone           String?
  email           String?
  photo           String? // URL de la photo
  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id])
  position        String // Poste / Fonction
  gradeId         String?
  grade           Grade?         @relation(fields: [gradeId], references: [id])
  orgLevelId      String?
  orgLevel        OrgLevel?      @relation(fields: [orgLevelId], references: [id])
  contractType    ContractType
  hireDate        DateTime
  contractEndDate DateTime? // Pour CDD/Stage
  trialEndDate    DateTime? // Fin de période d'essai
  baseSalary      Decimal        @db.Decimal(12, 2)
  currency        Currency       @default(MRU)
  status             EmployeeStatus      @default(ACTIVE)
  terminationDate    DateTime?           @db.Date
  terminationReason  TerminationReason?
  terminationNotes   String?             @db.Text
  managerId          String?
  manager         Employee?      @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates    Employee[]     @relation("ManagerRelation")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User?
  leaves          Leave[]
  payslips        Payslip[]
  documents       Document[]
  advantages      EmployeeAdvantage[]
  timeline        EmployeeTimeline[]
  onboardingTasks OnboardingTask[]
  signatures      SignatureRequest[]
  leaveBalances   LeaveBalance[]
  attendances     Attendance[]
  schedule        EmployeeSchedule?
  overtimes       Overtime[]
  salaryAdvances  SalaryAdvance[]
  expenseReports  ExpenseReport[]
  evaluations     Evaluation[]
  evaluationsGiven Evaluation[] @relation("EvaluatorRelation")
  sanctions        Sanction[]

  @@unique([tenantId, matricule])
  @@unique([tenantId, cin])
}

model Department {
  id               String       @id @default(uuid())
  tenantId         String
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  name             String
  description      String?
  managerId        String?
  parentId         String?
  parent           Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children         Department[] @relation("DepartmentHierarchy")
  orgLevelId       String?
  orgLevel         OrgLevel?    @relation(fields: [orgLevelId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  employees Employee[]

  @@unique([tenantId, name])
}

// ==========================================
// NIVEAUX HIÉRARCHIQUES (personnalisables)
// ==========================================

model OrgLevel {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String   // Ex: "Directeur Général", "Chef de Département"
  rank        Int      // Ordre hiérarchique (1 = plus haut, ex: DG)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees   Employee[]
  departments Department[]

  @@unique([tenantId, name])
  @@index([tenantId, rank])
}

// ==========================================
// GRADES & AVANTAGES
// ==========================================

model Grade {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  level       Int // Ordre hiérarchique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees  Employee[]
  advantages GradeAdvantage[]

  @@unique([tenantId, name])
}

model Advantage {
  id           String        @id @default(uuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  name         String // Ex: "Prime de transport"
  type         AdvantageType // PRIME, INDEMNITE, AVANTAGE_NATURE
  amount       Decimal?      @db.Decimal(12, 2)
  isPercentage Boolean       @default(false) // Si true, c'est un % du salaire de base
  isTaxable    Boolean       @default(true)
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  grades    GradeAdvantage[]
  employees EmployeeAdvantage[]
  sanctions Sanction[]

  @@unique([tenantId, name])
}

model GradeAdvantage {
  id           String    @id @default(uuid())
  gradeId      String
  grade        Grade     @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  advantageId  String
  advantage    Advantage @relation(fields: [advantageId], references: [id], onDelete: Cascade)
  customAmount Decimal?  @db.Decimal(12, 2) // Montant spécifique pour ce grade (override)

  @@unique([gradeId, advantageId])
}

model EmployeeAdvantage {
  id           String    @id @default(uuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  advantageId  String
  advantage    Advantage @relation(fields: [advantageId], references: [id])
  customAmount Decimal?  @db.Decimal(12, 2) // Override individuel si nécessaire
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean   @default(true)

  @@unique([employeeId, advantageId])
}

// ==========================================
// CONGÉS
// ==========================================

model LeaveType {
  id                    String   @id @default(uuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  name                  String // Ex: "Congé annuel", "Maladie"
  code                  String // Ex: "ANNUAL", "SICK"
  defaultDays           Int // Nombre de jours par défaut
  isPaid                Boolean  @default(true)
  requiresJustification Boolean  @default(false) // Justificatif obligatoire
  color                 String? // Couleur pour le calendrier
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  leaves Leave[]

  @@unique([tenantId, code])
}

model Leave {
  id               String      @id @default(uuid())
  employeeId       String
  employee         Employee    @relation(fields: [employeeId], references: [id])
  leaveTypeId      String
  leaveType        LeaveType   @relation(fields: [leaveTypeId], references: [id])
  startDate        DateTime
  endDate          DateTime
  totalDays        Decimal     @db.Decimal(4, 1) // Permet les demi-journées
  reason           String?
  status           LeaveStatus @default(PENDING)
  reviewedBy       String? // User ID du RH
  reviewedAt       DateTime?
  rejectionReason  String?
  justificationUrl String? // Fichier justificatif uploadé
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([employeeId, startDate])
  @@index([status])
}

model LeaveBalance {
  id            String   @id @default(uuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  leaveTypeCode String
  year          Int
  entitled      Decimal  @default(0) @db.Decimal(4, 1) // Jours acquis
  taken         Decimal  @default(0) @db.Decimal(4, 1) // Jours pris
  carriedOver   Decimal  @default(0) @db.Decimal(4, 1) // Jours reportés
  remaining     Decimal  @default(0) @db.Decimal(4, 1) // Solde restant
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, leaveTypeCode, year])
}

// ==========================================
// JOURS FÉRIÉS
// ==========================================

model Holiday {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  date        DateTime @db.Date
  isRecurring Boolean  @default(true) // Se répète chaque année (mois/jour fixe)
  createdAt   DateTime @default(now())

  @@unique([tenantId, date])
  @@index([tenantId, date])
}

// ==========================================
// PAIE
// ==========================================

model Payroll {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  month       Int // 1-12
  year        Int
  status      PayrollStatus @default(DRAFT)
  processedBy String? // User ID
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payslips Payslip[]

  @@unique([tenantId, month, year])
  @@index([tenantId, year, month])
}

model Payslip {
  id         String   @id @default(uuid())
  payrollId  String
  payroll    Payroll  @relation(fields: [payrollId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  // Éléments de rémunération
  baseSalary      Decimal @db.Decimal(12, 2)
  totalAdvantages Decimal @db.Decimal(12, 2) // Somme des avantages
  grossSalary     Decimal @db.Decimal(12, 2) // Salaire brut

  // Cotisations (législation mauritanienne)
  cnssEmployee Decimal @db.Decimal(12, 2) // CNSS part salariale
  cnssEmployer Decimal @db.Decimal(12, 2) // CNSS part patronale
  itsAmount    Decimal @db.Decimal(12, 2) // ITS (Impôt sur les Traitements et Salaires)

  // Heures supplémentaires
  overtimePay          Decimal @default(0) @db.Decimal(12, 2)

  // Retenues pointage (retards, absences, départs anticipés)
  attendanceDeductions Decimal @default(0) @db.Decimal(12, 2)

  // Acomptes sur salaire
  advanceDeductions    Decimal @default(0) @db.Decimal(12, 2)

  // Autres retenues
  otherDeductions Decimal @default(0) @db.Decimal(12, 2)

  // Net
  netSalary Decimal @db.Decimal(12, 2)

  // Détail des avantages (JSON)
  advantagesDetail Json? // [{name, amount, isTaxable}]
  deductionsDetail Json? // [{name, amount, type}]

  pdfUrl    String? // URL du bulletin PDF généré
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([payrollId, employeeId])
}

// ==========================================
// DÉCLARATIONS FISCALES
// ==========================================

model Declaration {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  type        DeclarationType
  period      String // Ex: "2024-Q1", "2024-03", "2024"
  status      DeclarationStatus @default(DRAFT)
  data        Json // Données calculées pour pré-remplir
  pdfUrl      String? // Document généré
  generatedBy String?
  generatedAt DateTime?
  submittedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ==========================================
// DOCUMENTS
// ==========================================

model Document {
  id          String       @id @default(uuid())
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id])
  type        DocumentType
  name        String
  url         String // URL du fichier stocké
  generatedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model SignatureRequest {
  id             String          @id @default(uuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  employeeId     String
  employee       Employee        @relation(fields: [employeeId], references: [id])
  documentType   DocumentType    @default(CONTRACT)
  title          String
  description    String?
  pdfPath        String?         // Generated PDF reference (employee contract, etc.)
  status         SignatureStatus @default(PENDING)
  signatureData  String?         @db.Text // Base64 canvas signature image
  requestedBy    String          // User ID who requested the signature
  requestedAt    DateTime        @default(now())
  signedAt       DateTime?
  expiresAt      DateTime?
  reminderSentAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// ==========================================
// ONBOARDING
// ==========================================

model OnboardingTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  tasks     Json // [{title, description, assignedRole, order}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OnboardingTask {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  title       String
  description String?
  assignedTo  String? // User ID
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  order       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==========================================
// TIMELINE / HISTORIQUE EMPLOYÉ
// ==========================================

model EmployeeTimeline {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  event       String // Ex: "HIRED", "PROMOTED", "LEAVE", "SALARY_CHANGE"
  description String
  oldValue    String?
  newValue    String?
  performedBy String? // User ID
  createdAt   DateTime @default(now())
}

// ==========================================
// AUDIT LOG (Super Admin monitoring)
// ==========================================

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ip         String?
  userAgent  String?
  statusCode Int?
  method     String?
  path       String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ==========================================
// POINTAGE / ATTENDANCE
// ==========================================

model AttendanceConfig {
  id                      String          @id @default(uuid())
  tenantId                String          @unique
  tenant                  Tenant          @relation(fields: [tenantId], references: [id])
  defaultStartTime        String          @default("08:00") // HH:mm
  defaultEndTime          String          @default("17:00") // HH:mm
  graceMinutes            Int             @default(10) // Tolérance retard
  deductionMethod         DeductionMethod @default(PER_MINUTE)
  fixedDeductionAmount    Decimal?        @db.Decimal(12, 2) // Montant fixe si FIXED
  tieredRules             Json? // [{maxMinutes: 15, deductionFraction: 0}, {maxMinutes: 30, deductionFraction: 0.25}, ...]
  earlyDepartureDeduction Boolean         @default(true) // Appliquer déduction départ anticipé
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
}

model EmployeeSchedule {
  id                String   @id @default(uuid())
  employeeId        String   @unique
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startTime         String   @default("08:00") // HH:mm
  endTime           String   @default("17:00") // HH:mm
  customGraceMinutes Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Attendance {
  id                    String           @id @default(uuid())
  tenantId              String
  tenant                Tenant           @relation(fields: [tenantId], references: [id])
  employeeId            String
  employee              Employee         @relation(fields: [employeeId], references: [id])
  date                  DateTime         @db.Date
  clockIn               DateTime? // Heure d'arrivée effective
  clockOut              DateTime? // Heure de départ effective
  scheduledStart        String // Snapshot heure prévue (HH:mm)
  scheduledEnd          String // Snapshot heure prévue (HH:mm)
  status                AttendanceStatus @default(PRESENT)
  lateMinutes           Int              @default(0)
  earlyDepartureMinutes Int              @default(0)
  deductionAmount       Decimal          @default(0) @db.Decimal(12, 2)
  note                  String?
  recordedBy            String? // User ID du HR
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([tenantId, employeeId, date])
  @@index([tenantId, date])
  @@index([employeeId])
  @@index([date])
}

// ==========================================
// HEURES SUPPLÉMENTAIRES
// ==========================================

model OvertimeConfig {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tiers     Json // [{tier: "TIER_1", label: "Majoration 25%", rate: 1.25, maxHours: 8}, ...]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Overtime {
  id         String       @id @default(uuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  employeeId String
  employee   Employee     @relation(fields: [employeeId], references: [id])
  date       DateTime     @db.Date
  hours      Decimal      @db.Decimal(5, 2)
  tier       OvertimeTier @default(TIER_1)
  rate       Decimal      @db.Decimal(4, 2) // Snapshot du taux au moment de la saisie
  reason     String?
  recordedBy String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([tenantId, employeeId, date, tier])
  @@index([tenantId, date])
  @@index([employeeId])
}

// ==========================================
// ACOMPTES SUR SALAIRE
// ==========================================

model SalaryAdvance {
  id                  String              @id @default(uuid())
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  employeeId          String
  employee            Employee            @relation(fields: [employeeId], references: [id])
  amount              Decimal             @db.Decimal(12, 2)
  requestDate         DateTime            @default(now())
  reason              String?
  status              SalaryAdvanceStatus @default(PENDING)
  reviewedBy          String?
  reviewedAt          DateTime?
  rejectionReason     String?
  deductedInPayslipId String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}

// ==========================================
// CONFIGURATION FISCALE PAR TENANT
// ==========================================

model TaxConfig {
  id               String  @id @default(uuid())
  tenantId         String  @unique
  tenant           Tenant  @relation(fields: [tenantId], references: [id])
  cnssEmployeeRate Decimal @default(0.01) @db.Decimal(5, 4)
  cnssEmployerRate Decimal @default(0.13) @db.Decimal(5, 4)
  cnssCeiling      Decimal @default(70000) @db.Decimal(12, 2)
  itsBrackets      Json // [{min: 0, max: 9000, rate: 0}, {min: 9000, max: 21000, rate: 0.15}, ...]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==========================================
// NOTES DE FRAIS
// ==========================================

model ExpenseReport {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id])
  title       String
  totalAmount Decimal       @default(0) @db.Decimal(12, 2)
  status      ExpenseStatus @default(DRAFT)
  submittedAt DateTime?
  reviewedBy  String?
  reviewedAt  DateTime?
  rejectionReason String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items ExpenseItem[]

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}

model ExpenseItem {
  id              String        @id @default(uuid())
  expenseReportId String
  expenseReport   ExpenseReport @relation(fields: [expenseReportId], references: [id], onDelete: Cascade)
  category        ExpenseCategory
  description     String
  amount          Decimal       @db.Decimal(12, 2)
  date            DateTime      @db.Date
  receiptUrl      String?
  createdAt       DateTime      @default(now())
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  HR
  EMPLOYEE
}

enum Gender {
  MALE
  FEMALE
}

enum ContractType {
  CDI
  CDD
  STAGE
  PRESTATION
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum TerminationReason {
  RESIGNATION       // Démission
  DISMISSAL         // Licenciement
  MUTUAL_AGREEMENT  // Rupture conventionnelle
  END_OF_CONTRACT   // Fin de contrat (CDD/Stage)
  RETIREMENT        // Retraite
  LAYOFF            // Licenciement économique
  ABANDONMENT       // Abandon de poste
  DEATH             // Décès
}

enum Currency {
  MRU // Ouguiya mauritanien
  EUR
  USD
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveCarryOverPolicy {
  NONE // Pas de report
  CAPPED // Report plafonné
  UNLIMITED // Report illimité
  CONFIGURABLE // Configurable
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  VALIDATED
  CLOSED
}

enum DeclarationType {
  DAS_UNITE_MIXTE
  DAS_DGI
  ITS_DGI
  ITS_GTA
  TAXE_APPRENTISSAGE_DGI
}

enum DeclarationStatus {
  DRAFT
  GENERATED
  SUBMITTED
}

enum DocumentType {
  CONTRACT
  PAYSLIP
  ATTESTATION
  JUSTIFICATION
  BADGE
  OTHER
}

enum SignatureStatus {
  PENDING
  SIGNED
  EXPIRED
  CANCELLED
}

enum AdvantageType {
  PRIME
  INDEMNITE
  AVANTAGE_NATURE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EARLY_DEPARTURE
  LATE_AND_EARLY
}

enum DeductionMethod {
  PER_MINUTE
  TIERED
  FIXED
}

enum OvertimeTier {
  TIER_1 // Majoration 25%
  TIER_2 // Majoration 50%
  TIER_3 // Majoration 100% (nuit/weekend/férié)
}

enum SalaryAdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  DEDUCTED // Déduit du bulletin de paie
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

enum ExpenseCategory {
  TRANSPORT
  MEALS
  ACCOMMODATION
  SUPPLIES
  COMMUNICATION
  TRAINING
  OTHER
}

// ==========================================
// PERFORMANCE EVALUATIONS
// ==========================================

model EvaluationCampaign {
  id          String               @id @default(uuid())
  tenantId    String
  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      EvaluationCampaignStatus @default(DRAFT)
  criteria    Json                 // [{name: string, weight: number, description?: string}]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  evaluations Evaluation[]
}

model Evaluation {
  id           String              @id @default(uuid())
  tenantId     String
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  campaignId   String
  campaign     EvaluationCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee            @relation(fields: [employeeId], references: [id])
  evaluatorId  String?
  evaluator    Employee?           @relation("EvaluatorRelation", fields: [evaluatorId], references: [id])
  scores       Json?               // [{criterionName: string, score: number, comment?: string}]
  overallScore Decimal?            @db.Decimal(4, 2) // 0.00 – 10.00
  strengths    String?             @db.Text
  improvements String?             @db.Text
  objectives   String?             @db.Text // Objectifs pour la période suivante
  status       EvaluationStatus    @default(PENDING)
  completedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([campaignId, employeeId])
}

enum EvaluationCampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum EvaluationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ==========================================
// SANCTIONS
// ==========================================

model Sanction {
  id              String         @id @default(uuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  type            SanctionType
  reason          String         @db.Text
  comment         String?        @db.Text
  date            DateTime       @db.Date
  advantageId     String?        // Prime spécifique visée (optionnel)
  advantage       Advantage?     @relation(fields: [advantageId], references: [id])
  deductionAmount Decimal        @db.Decimal(12, 2) // Montant déduit
  issuedBy        String         // User ID
  status          SanctionStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}

enum SanctionType {
  DEDUCTION_PRIME   // Déduction sur prime spécifique
  RETENUE_SALAIRE   // Retenue directe sur salaire
  AVERTISSEMENT     // Avertissement (pas d'impact financier)
  MISE_A_PIED       // Mise à pied (suspension)
}

enum SanctionStatus {
  ACTIVE
  ARCHIVED
}
